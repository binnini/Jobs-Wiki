# WorkNet Open API auth keys
EMPLOYMENT_INFO=your-worknet-employment-auth-key
NATIONAL_TRAINING=
BUSINESS_TRAINING=
NATIONAL_HUMAN_RESOURCES=
JOB_SEEKER_EMPLOYMENT=
DEPARTMENT_INFO=
SMALL_GIANT_COMPANY=
JOB_INFORMATION=
JOB_DESCRIPTIONS=
WORK_WITH_STUDY_TRAINING=

# Ingestion runtime
INGEST_SERVICE_NAME=jobs-wiki-ingestion
INGEST_LOG_LEVEL=info
INGEST_DRY_RUN=true
INGEST_RUN_SUMMARY_DIR=
INGEST_MAX_ATTEMPTS=3
INGEST_RETRY_DELAY_MS=1000
INGEST_SCHEDULE_INTERVAL_MS=300000
INGEST_SCHEDULE_CYCLES=1
INGEST_SOURCE=worknet
WORKNET_SOURCE_ID=worknet.recruiting
WORKNET_FETCH_PAGE=1
WORKNET_FETCH_SIZE=5
WORKNET_BACKFILL_START_PAGE=1
WORKNET_BACKFILL_PAGES=3

# StrataWiki integration mode
STRATAWIKI_INTEGRATION_MODE=auto
STRATAWIKI_BASE_URL=http://127.0.0.1:8080
STRATAWIKI_API_TOKEN=
STRATAWIKI_HTTP_TIMEOUT_MS=10000

# StrataWiki wrapper rollback path
STRATAWIKI_CLI_WRAPPER=/Users/yebin/workSpace/stratawiki-runtime/bin/stratawiki-jobswiki.sh
JOBS_WIKI_STRATAWIKI_DOMAIN_PACK_PATHS=/Users/yebin/workSpace/Jobs-Wiki/packages/domain-packs/recruiting/v1.json
JOBS_WIKI_STRATAWIKI_ACTIVE_DOMAIN_PACKS=recruiting=2026-04-18

# WAS real read adapter
WAS_DATA_MODE=real
STRATAWIKI_READ_DATABASE_URL=postgresql://stratawiki:stratawiki@localhost:5432/stratawiki_jobswiki
STRATAWIKI_READ_PSQL_BIN=psql
STRATAWIKI_READ_DOMAIN=recruiting
STRATAWIKI_READ_SCOPE=shared

# WAS command facade
# Manual WorkNet refresh needs these command tools to exist in the active runtime.
STRATAWIKI_COMMAND_SUBMIT_TOOL=knowledge.command.submit
STRATAWIKI_COMMAND_STATUS_TOOL=knowledge.command.get

# WAS personal-aware ask
JOBS_WIKI_PROFILE_CONTEXT_CATALOG_PATH=/Users/yebin/workSpace/Jobs-Wiki/apps/was/src/fixtures/profile-context-catalog.json
STRATAWIKI_PERSONAL_QUERY_MODEL_PROFILE=balanced_default
STRATAWIKI_GET_PROFILE_CONTEXT_TOOL=get_profile_context
STRATAWIKI_UPSERT_PROFILE_CONTEXT_TOOL=upsert_profile_context
STRATAWIKI_PERSONAL_QUERY_TOOL=query_personal_knowledge
STRATAWIKI_GET_PERSONAL_RECORD_TOOL=get_personal_record
STRATAWIKI_GET_INTERPRETATION_RECORD_TOOL=get_interpretation_record
STRATAWIKI_GET_FACT_RECORD_TOOL=get_fact_record

# Frontend demo user context
VITE_JOBS_WIKI_WORKSPACE_ID=workspace_demo
VITE_JOBS_WIKI_PROFILE_ID=profile_demo_backend
