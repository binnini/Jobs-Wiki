<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.jobswiki.worknet.daily</string>

    <key>ProgramArguments</key>
    <array>
      <string>/Users/yebin/workSpace/Ontology/Jobs-Wiki/scripts/run-worknet-daily-batch.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/yebin/workSpace/Ontology/Jobs-Wiki</string>

