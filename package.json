{
  "name": "jobs-wiki",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:frontend": "npm --prefix apps/frontend run dev",
    "build:frontend": "npm --prefix apps/frontend run build",
    "preview:frontend": "npm --prefix apps/frontend run preview",
    "dev:ingestion": "npm --prefix apps/ingestion run dev",
    "start:ingestion": "npm --prefix apps/ingestion run start",
    "test:ingestion": "npm --prefix apps/ingestion run test",
    "ingest:worknet": "npm --prefix apps/ingestion run ingest:worknet",
    "ingest:worknet:apply": "npm --prefix apps/ingestion run ingest:worknet:apply",
    "ingest:worknet:incremental": "npm --prefix apps/ingestion run ingest:worknet:incremental",
    "ingest:worknet:schedule": "npm --prefix apps/ingestion run ingest:worknet:schedule",
    "ingest:worknet:backfill": "npm --prefix apps/ingestion run ingest:worknet:backfill",
    "dev:was": "WAS_DATA_MODE=${WAS_DATA_MODE:-real} npm --prefix apps/was run dev",
    "start:was": "WAS_DATA_MODE=${WAS_DATA_MODE:-real} npm --prefix apps/was run start",
    "test:was": "npm --prefix apps/was run test",
    "verify:mvp": "npm run test:was && npm run build:frontend",
    "smoke:live": "node scripts/live-integration-smoke.mjs",
    "smoke:http": "node scripts/http-rest-smoke.mjs",
    "smoke:http:cross-repo": "node scripts/cross-repo-http-smoke.mjs",
    "smoke:stack": "node scripts/local-stack-http-smoke.mjs",
    "test:domain-pack": "node --test tests/domain-packs/recruiting-pack.test.mjs",
    "test:domain-pack:fixtures": "node --test tests/domain-packs/recruiting-governance-fixtures.test.ts",
    "test:domain-pack:mapper": "node --test tests/domain-packs/recruiting-proposal-mapper.test.ts",
    "test:stratawiki-http": "node --test packages/integrations/stratawiki-http/test/client.test.js",
    "test:worknet": "node tests/worknet/smoke.mjs",
    "test:worknet:mappers": "node --test packages/integrations/worknet/test/mappers.test.ts",
    "test:worknet:providers": "node --test packages/integrations/worknet/test/recruiting-provider.test.ts"
  }
}
